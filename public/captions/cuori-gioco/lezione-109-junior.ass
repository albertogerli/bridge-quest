Dialogue: 0,0:0:0.00,0:0:0.34,Default,,0000,0000,0000,,Ciao! 
Dialogue: 0,0:0:0.34,0:0:1.85,Default,,0000,0000,0000,,Bentornato a BridgeQuest ! 
Dialogue: 0,0:0:1.85,0:0:4.55,Default,,0000,0000,0000,,Siamo all'ultima lezione \ndel corso Cuori Gioco 
Dialogue: 0,0:0:4.55,0:0:6.91,Default,,0000,0000,0000,,e oggi parliamo di \nqualcosa che ti fara' 
Dialogue: 0,0:0:6.91,0:0:9.44,Default,,0000,0000,0000,,sentire un vero \ndetective: le deduzioni del 
Dialogue: 0,0:0:9.44,0:0:10.00,Default,,0000,0000,0000,,giocante! 
Dialogue: 0,0:0:10.00,0:0:12.65,Default,,0000,0000,0000,,Come disse Arthur Conan \nDoyle, il creatore di 
Dialogue: 0,0:0:12.65,0:0:15.17,Default,,0000,0000,0000,,Sherlock Holmes: `` Una \ndeduzione giusta ne 
Dialogue: 0,0:0:15.17,0:0:17.14,Default,,0000,0000,0000,,suggerisce \ninvariabilmente altre. 
Dialogue: 0,0:0:17.14,0:0:19.78,Default,,0000,0000,0000,,'' E al tavolo da bridge \nfunziona esattamente 
Dialogue: 0,0:0:19.78,0:0:20.18,Default,,0000,0000,0000,,cosi'. 
Dialogue: 0,0:0:20.18,0:0:22.82,Default,,0000,0000,0000,,Le informazioni al \nbridge non vengono solo da 
Dialogue: 0,0:0:22.82,0:0:24.67,Default,,0000,0000,0000,,quello che gli avversari \nFANNO. 
Dialogue: 0,0:0:24.67,0:0:27.31,Default,,0000,0000,0000,,Vengono soprattutto da \nquello che NON fanno e 
Dialogue: 0,0:0:27.31,0:0:27.99,Default,,0000,0000,0000,,NON dicono! 
Dialogue: 0,0:0:27.99,0:0:30.57,Default,,0000,0000,0000,,Se un avversario passa, \nsignifica che non ha 
Dialogue: 0,0:0:30.57,0:0:32.82,Default,,0000,0000,0000,,l'apertura, cioe' non ha \ndodici punti. 
Dialogue: 0,0:0:32.82,0:0:35.35,Default,,0000,0000,0000,,Se non interviene con un \nbel colore quinto, 
Dialogue: 0,0:0:35.35,0:0:37.43,Default,,0000,0000,0000,,probabilmente non ha \nvalori a lato. 
Dialogue: 0,0:0:37.43,0:0:40.07,Default,,0000,0000,0000,,Ogni passo, ogni \nsilenzio, e' un'informazione 
Dialogue: 0,0:0:40.07,0:0:40.63,Default,,0000,0000,0000,,preziosa. 
Dialogue: 0,0:0:40.63,0:0:42.99,Default,,0000,0000,0000,,Cominciamo dalle \ndeduzioni dall'attacco. 
Dialogue: 0,0:0:42.99,0:0:45.52,Default,,0000,0000,0000,,L'attacco e' l'unica \nmossa che la difesa fa 
Dialogue: 0,0:0:45.52,0:0:47.55,Default,,0000,0000,0000,,alla cieca, senza vedere \nil morto. 
Dialogue: 0,0:0:47.55,0:0:50.19,Default,,0000,0000,0000,,Per questo i giocatori \nseguono regole precise 
Dialogue: 0,0:0:50.19,0:0:51.09,Default,,0000,0000,0000,,nell'attaccare. 
Dialogue: 0,0:0:51.09,0:0:53.67,Default,,0000,0000,0000,,E tu puoi sfruttare \nqueste regole per capire 
Dialogue: 0,0:0:53.67,0:0:54.35,Default,,0000,0000,0000,,cosa hanno! 
Dialogue: 0,0:0:54.35,0:0:56.88,Default,,0000,0000,0000,,A Senza Atout: se \nl'avversario ha esitato a 
Dialogue: 0,0:0:56.88,0:0:59.52,Default,,0000,0000,0000,,lungo prima di attaccare \nprobabilmente non ha 
Dialogue: 0,0:0:59.52,0:1:0.53,Default,,0000,0000,0000,,una buona quinta. 
Dialogue: 0,0:1:0.53,0:1:3.00,Default,,0000,0000,0000,,Non aveva un colore \nnaturale da attaccare. 
Dialogue: 0,0:1:3.00,0:1:5.70,Default,,0000,0000,0000,,Se non ti attacca nel \ncolore `` ovvio '', cioe 
Dialogue: 0,0:1:5.70,0:1:8.40,Default,,0000,0000,0000,,l'unico colore non \ndichiarato dalla tua coppia 
Dialogue: 0,0:1:8.40,0:1:10.93,Default,,0000,0000,0000,,probabilmente ha una \nfigura imbarazzante in 
Dialogue: 0,0:1:10.93,0:1:13.18,Default,,0000,0000,0000,,quel colore, tipo \nAsso-Donna-piccola o 
Dialogue: 0,0:1:13.18,0:1:14.07,Default,,0000,0000,0000,,Re-Fante-Dieci. 
Dialogue: 0,0:1:14.07,0:1:16.77,Default,,0000,0000,0000,,Ad Atout le deduzioni \nsono ancora piu' ricche. 
Dialogue: 0,0:1:16.77,0:1:19.41,Default,,0000,0000,0000,,Se l'attacco e' una \ncartina senza particolari 
Dialogue: 0,0:1:19.41,0:1:22.06,Default,,0000,0000,0000,,meriti, l'attaccante non \naveva sequenze negli 
Dialogue: 0,0:1:22.06,0:1:22.84,Default,,0000,0000,0000,,altri colori. 
Dialogue: 0,0:1:22.84,0:1:24.98,Default,,0000,0000,0000,,Non aveva Asso-Re, ne' \nRe-Donna, ne' 
Dialogue: 0,0:1:24.98,0:1:26.50,Default,,0000,0000,0000,,Donna-Fante, ne' singoli . 
Dialogue: 0,0:1:26.50,0:1:28.07,Default,,0000,0000,0000,,E' un'informazione \nenorme! 
Dialogue: 0,0:1:28.07,0:1:30.82,Default,,0000,0000,0000,,Vuol dire che le figure \ndegli altri colori sono 
Dialogue: 0,0:1:30.82,0:1:33.24,Default,,0000,0000,0000,,distribuite in modo \ndiverso da quello che 
Dialogue: 0,0:1:33.24,0:1:34.25,Default,,0000,0000,0000,,potresti pensare. 
Dialogue: 0,0:1:34.25,0:1:36.67,Default,,0000,0000,0000,,Se gli avversari si sono \nappoggiati in un 
Dialogue: 0,0:1:36.67,0:1:39.37,Default,,0000,0000,0000,,colore durante la \ndichiarazione ma l'attacco e 
Dialogue: 0,0:1:39.37,0:1:42.06,Default,,0000,0000,0000,,in un altro colore, la \nragione puo' essere che 
Dialogue: 0,0:1:42.06,0:1:44.59,Default,,0000,0000,0000,,l'attaccante ha un \nsingolo nel suo colore o 
Dialogue: 0,0:1:44.59,0:1:46.67,Default,,0000,0000,0000,,Asso-Donna nel colore \ndel compagno. 
Dialogue: 0,0:1:46.67,0:1:49.20,Default,,0000,0000,0000,,Un attacco da probabile \nsingolo ti dice che 
Dialogue: 0,0:1:49.20,0:1:51.96,Default,,0000,0000,0000,,l'attaccante \nprobabilmente non ha una figura di 
Dialogue: 0,0:1:51.96,0:1:54.43,Default,,0000,0000,0000,,atout naturale come \nDonna-piccola-piccola, 
Dialogue: 0,0:1:54.43,0:1:57.18,Default,,0000,0000,0000,,perche' con quella \navrebbe preferito un attacco 
Dialogue: 0,0:1:57.18,0:1:55.44,Default,,0000,0000,0000,,piu' neutro. 
Dialogue: 0,0:1:55.44,0:1:58.17,Default,,0000,0000,0000,,Adesso passiamo alle \ndeduzioni dalla licita. 
Dialogue: 0,0:1:58.17,0:2:1.07,Default,,0000,0000,0000,,Questa e' la parte dove \ndiventi Sherlock Holmes 
Dialogue: 0,0:2:1.07,0:2:1.19,Default,,0000,0000,0000,,! 
Dialogue: 0,0:2:1.19,0:2:3.98,Default,,0000,0000,0000,,La regola d'oro: chi \npassa non ha l'apertura. 
Dialogue: 0,0:2:3.98,0:2:6.59,Default,,0000,0000,0000,,Se un avversario e' \npassato di mano, ha al 
Dialogue: 0,0:2:6.59,0:2:7.89,Default,,0000,0000,0000,,massimo undici punti. 
Dialogue: 0,0:2:7.89,0:2:10.74,Default,,0000,0000,0000,,Questa e' una deduzione \novvia ma fondamentale, 
Dialogue: 0,0:2:10.74,0:2:12.76,Default,,0000,0000,0000,,che molti giocatori \ndimenticano! 
Dialogue: 0,0:2:12.76,0:2:15.01,Default,,0000,0000,0000,,Esempio fantastico: sei \nin 4 Picche. 
Dialogue: 0,0:2:15.01,0:2:16.91,Default,,0000,0000,0000,,Ovest attacca Donna di \nquadri. 
Dialogue: 0,0:2:16.91,0:2:19.46,Default,,0000,0000,0000,,Deduzione: Ovest non ha \nAsso-Re di cuori, 
Dialogue: 0,0:2:19.46,0:2:22.36,Default,,0000,0000,0000,,perche' con Re-Donna di \ncuori avrebbe preferito 
Dialogue: 0,0:2:22.36,0:2:23.25,Default,,0000,0000,0000,,quell'attacco. 
Dialogue: 0,0:2:23.25,0:2:25.21,Default,,0000,0000,0000,,Quindi il Re di cuori e \nin Est. 
Dialogue: 0,0:2:25.21,0:2:27.82,Default,,0000,0000,0000,,Ma Est e' passato di \nmano e non puo' avere 
Dialogue: 0,0:2:27.82,0:2:28.53,Default,,0000,0000,0000,,l'apertura. 
Dialogue: 0,0:2:28.53,0:2:31.32,Default,,0000,0000,0000,,Se ha il Re di cuori, \nnon puo' avere anche le 
Dialogue: 0,0:2:31.32,0:2:32.45,Default,,0000,0000,0000,,due Dame mancanti. 
Dialogue: 0,0:2:32.45,0:2:34.82,Default,,0000,0000,0000,,Quindi niente impasse a \npicche su Est! 
Dialogue: 0,0:2:34.82,0:2:37.72,Default,,0000,0000,0000,,Invece, fai l'impasse a \nquadri su Ovest e batti 
Dialogue: 0,0:2:37.72,0:2:39.38,Default,,0000,0000,0000,,Asso-Re di fiori in \ntesta. 
Dialogue: 0,0:2:39.38,0:2:40.22,Default,,0000,0000,0000,,Undici prese! 
Dialogue: 0,0:2:40.22,0:2:41.99,Default,,0000,0000,0000,,Altro caso: sei in 5 \nQuadri. 
Dialogue: 0,0:2:41.99,0:2:44.66,Default,,0000,0000,0000,,Est ha mostrato due Assi \ne certamente ha la 
Dialogue: 0,0:2:44.66,0:2:45.67,Default,,0000,0000,0000,,Donna di picche. 
Dialogue: 0,0:2:45.67,0:2:48.28,Default,,0000,0000,0000,,Se avesse ANCHE la Donna \ndi fiori, avrebbe 
Dialogue: 0,0:2:48.28,0:2:51.13,Default,,0000,0000,0000,,avuto abbastanza punti \nper aprire, e invece ha 
Dialogue: 0,0:2:51.13,0:2:51.66,Default,,0000,0000,0000,,passato. 
Dialogue: 0,0:2:51.66,0:2:54.45,Default,,0000,0000,0000,,Quindi la Donna di fiori \ne' in Ovest: impasse 
Dialogue: 0,0:2:54.45,0:2:55.04,Default,,0000,0000,0000,,su Ovest. 
Dialogue: 0,0:2:55.04,0:2:57.53,Default,,0000,0000,0000,,E ancora: sei in 4 \nPicche e Ovest non e' 
Dialogue: 0,0:2:57.53,0:2:59.73,Default,,0000,0000,0000,,entrato in dichiarazione \npur avendo 
Dialogue: 0,0:2:59.73,0:3:2.40,Default,,0000,0000,0000,,Asso-Re-piccola-piccola- \npiccola-piccola di 
Dialogue: 0,0:3:2.40,0:3:2.87,Default,,0000,0000,0000,,quadri. 
Dialogue: 0,0:3:2.87,0:3:5.72,Default,,0000,0000,0000,,Con quel bel colore, se \navesse avuto anche una 
Dialogue: 0,0:3:5.72,0:3:8.09,Default,,0000,0000,0000,,Donna avrebbe \nsicuramente interferito. 
Dialogue: 0,0:3:8.09,0:3:8.98,Default,,0000,0000,0000,,Ma ha taciuto. 
Dialogue: 0,0:3:8.98,0:3:11.23,Default,,0000,0000,0000,,Quindi le Dame mancanti \nsono in Est. 
Dialogue: 0,0:3:11.23,0:3:12.65,Default,,0000,0000,0000,,Impasse a fiori su Est! 
Dialogue: 0,0:3:12.65,0:3:14.85,Default,,0000,0000,0000,,Le deduzioni funzionano \nanche sulla 
Dialogue: 0,0:3:14.85,0:3:15.74,Default,,0000,0000,0000,,distribuzione. 
Dialogue: 0,0:3:15.74,0:3:18.64,Default,,0000,0000,0000,,Se Est ha aperto 1 Fiori \ncon un doubleton fiori 
Dialogue: 0,0:3:18.64,0:3:21.43,Default,,0000,0000,0000,,l'unica mano che apre 1 \nFiori in due carte e' 
Dialogue: 0,0:3:21.43,0:3:23.15,Default,,0000,0000,0000,,la \nquattro-quattro-tre-due. 
Dialogue: 0,0:3:23.15,0:3:26.00,Default,,0000,0000,0000,,Quindi Est ha \nesattamente quattro carte in due 
Dialogue: 0,0:3:26.00,0:3:28.07,Default,,0000,0000,0000,,colori, tre in uno e due \na fiori. 
Dialogue: 0,0:3:28.07,0:3:30.92,Default,,0000,0000,0000,,Se gli atout sono cuori \ne Est ha quattro cuori 
Dialogue: 0,0:3:30.92,0:3:32.46,Default,,0000,0000,0000,,ripeti l'impasse su Est ! 
Dialogue: 0,0:3:32.46,0:3:35.31,Default,,0000,0000,0000,,Ultimo trucco: conta i \npunti che un avversario 
Dialogue: 0,0:3:35.31,0:3:36.38,Default,,0000,0000,0000,,ha gia' mostrato. 
Dialogue: 0,0:3:36.38,0:3:39.16,Default,,0000,0000,0000,,Se Ovest ha incassato \nAsso-Re-Donna di fiori, 
Dialogue: 0,0:3:39.16,0:3:40.47,Default,,0000,0000,0000,,sono gia' nove punti. 
Dialogue: 0,0:3:40.47,0:3:43.37,Default,,0000,0000,0000,,Se era passato di mano, \nnon puo' avere anche il 
Dialogue: 0,0:3:43.37,0:3:46.04,Default,,0000,0000,0000,,Re di picche, che gli \ndarebbe dodici punti. 
Dialogue: 0,0:3:46.04,0:3:48.83,Default,,0000,0000,0000,,Quindi il Re di picche e \nin Est, e un impasse 
Dialogue: 0,0:3:48.83,0:3:51.56,Default,,0000,0000,0000,,`` destinato ad andare \nmale '' non va fatto. 
Dialogue: 0,0:3:51.56,0:3:53.81,Default,,0000,0000,0000,,Gioca per il Re secco \ndietro l'Asso! 
Dialogue: 0,0:3:53.81,0:3:56.48,Default,,0000,0000,0000,,Questa e' stata l'ultima \nlezione del corso. 
Dialogue: 0,0:3:56.48,0:3:59.33,Default,,0000,0000,0000,,Hai imparato tantissimo \ndalle prime prese alla 
Dialogue: 0,0:3:59.33,0:4:2.11,Default,,0000,0000,0000,,probabilita', dalla \nsicurezza alle deduzioni. 
Dialogue: 0,0:4:2.11,0:4:3.78,Default,,0000,0000,0000,,Complimenti e buon \nbridge! 
