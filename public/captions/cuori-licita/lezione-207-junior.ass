Dialogue: 0,0:0:0.00,0:0:0.38,Default,,0000,0000,0000,,Ciao! 
Dialogue: 0,0:0:0.38,0:0:3.19,Default,,0000,0000,0000,,Oggi parliamo \ndell'apertura piu' potente di 
Dialogue: 0,0:0:3.19,0:0:6.26,Default,,0000,0000,0000,,tutto il bridge: il 2 \nFiori forte indeterminata 
Dialogue: 0,0:0:6.26,0:0:6.39,Default,,0000,0000,0000,,! 
Dialogue: 0,0:0:6.39,0:0:9.15,Default,,0000,0000,0000,,Quando hai una mano cosi \nforte che nessuna 
Dialogue: 0,0:0:9.15,0:0:12.21,Default,,0000,0000,0000,,altra apertura le rende \ngiustizia, apri 2 Fiori 
Dialogue: 0,0:0:12.21,0:0:12.34,Default,,0000,0000,0000,,. 
Dialogue: 0,0:0:12.34,0:0:15.41,Default,,0000,0000,0000,,Non c' e' limite \nsuperiore: puoi avere 22 punti 
Dialogue: 0,0:0:15.41,0:0:17.10,Default,,0000,0000,0000,,25 punti, anche 30 punti ! 
Dialogue: 0,0:0:17.10,0:0:20.17,Default,,0000,0000,0000,,L'idea e' semplice: 2 \nFiori dice `` ho una mano 
Dialogue: 0,0:0:20.17,0:0:20.92,Default,,0000,0000,0000,,fortissima. 
Dialogue: 0,0:0:20.92,0:0:22.93,Default,,0000,0000,0000,,'' Non dice nulla sulle \nfiori! 
Dialogue: 0,0:0:22.93,0:0:25.81,Default,,0000,0000,0000,,Il nome del colore non \nc'entra niente con il 
Dialogue: 0,0:0:25.81,0:0:27.25,Default,,0000,0000,0000,,seme che vuoi giocare. 
Dialogue: 0,0:0:27.25,0:0:30.13,Default,,0000,0000,0000,,Per questo si chiama `` \nindeterminata '': la 
Dialogue: 0,0:0:30.13,0:0:33.14,Default,,0000,0000,0000,,mano puo' essere di \nqualsiasi tipo, bilanciata 
Dialogue: 0,0:0:33.14,0:0:35.89,Default,,0000,0000,0000,,o sbilanciata, con \nqualsiasi colore lungo. 
Dialogue: 0,0:0:35.89,0:0:38.46,Default,,0000,0000,0000,,E dato che hai la mano \nforte, sei tu il 
Dialogue: 0,0:0:38.46,0:0:39.09,Default,,0000,0000,0000,,Capitano. 
Dialogue: 0,0:0:39.09,0:0:42.16,Default,,0000,0000,0000,,Il compagno ti aiuta a \ndescrivere la situazione 
Dialogue: 0,0:0:42.16,0:0:44.60,Default,,0000,0000,0000,,ma le decisioni finali \nspettano a te. 
Dialogue: 0,0:0:44.60,0:0:45.91,Default,,0000,0000,0000,,Vediamo le risposte. 
Dialogue: 0,0:0:45.91,0:0:48.92,Default,,0000,0000,0000,,La risposta piu' comune \ne' 2 Quadri, ed e' una 
Dialogue: 0,0:0:48.92,0:0:51.11,Default,,0000,0000,0000,,risposta convenzionale \ndi attesa. 
Dialogue: 0,0:0:51.11,0:0:52.99,Default,,0000,0000,0000,,Non dice nulla sulle \nquadri! 
Dialogue: 0,0:0:52.99,0:0:55.62,Default,,0000,0000,0000,,Dice solo: `` Non ho i \nrequisiti per una 
Dialogue: 0,0:0:55.62,0:0:57.88,Default,,0000,0000,0000,,risposta specifica, \ndimmi di piu'. 
Dialogue: 0,0:0:57.88,0:1:0.51,Default,,0000,0000,0000,,'' Con 2 Quadri puoi \navere da zero punti 
Dialogue: 0,0:1:0.51,0:1:3.52,Default,,0000,0000,0000,,all'infinito, bilanciate \no sbilanciate deboli. 
Dialogue: 0,0:1:3.52,0:1:6.21,Default,,0000,0000,0000,,E' la risposta che darai \nnella stragrande 
Dialogue: 0,0:1:6.21,0:1:7.59,Default,,0000,0000,0000,,maggioranza dei casi. 
Dialogue: 0,0:1:7.59,0:1:10.22,Default,,0000,0000,0000,,Le risposte specifiche \nsono piu' rare ma 
Dialogue: 0,0:1:10.22,0:1:10.97,Default,,0000,0000,0000,,importanti. 
Dialogue: 0,0:1:10.97,0:1:13.91,Default,,0000,0000,0000,,2 Cuori e 2 Picche sono \nrisposte naturali che 
Dialogue: 0,0:1:13.91,0:1:16.73,Default,,0000,0000,0000,,mostrano almeno cinque \ncarte nel colore con 
Dialogue: 0,0:1:16.73,0:1:19.61,Default,,0000,0000,0000,,almeno un onore, PIU' \nforza di manche, cioe' 
Dialogue: 0,0:1:19.61,0:1:20.62,Default,,0000,0000,0000,,almeno 5 punti. 
Dialogue: 0,0:1:20.62,0:1:23.69,Default,,0000,0000,0000,,Servono tutti e tre i \nrequisiti insieme: cinque 
Dialogue: 0,0:1:23.69,0:1:25.69,Default,,0000,0000,0000,,carte, un onore, cinque \npunti. 
Dialogue: 0,0:1:25.69,0:1:27.76,Default,,0000,0000,0000,,Se ne manca uno, dici 2 \nQuadri. 
Dialogue: 0,0:1:27.76,0:1:30.14,Default,,0000,0000,0000,,Poi ci sono le risposte \na livello 3. 
Dialogue: 0,0:1:30.14,0:1:32.96,Default,,0000,0000,0000,,3 Cuori e 3 Picche, \nmolto rare, mostrano un 
Dialogue: 0,0:1:32.96,0:1:35.84,Default,,0000,0000,0000,,colore di almeno sei \ncarte capeggiato da tre 
Dialogue: 0,0:1:35.84,0:1:38.09,Default,,0000,0000,0000,,onori maggiori o due piu \nil Fante. 
Dialogue: 0,0:1:38.09,0:1:40.97,Default,,0000,0000,0000,,3 Fiori e 3 Quadri \nmostrano cinque carte con 
Dialogue: 0,0:1:40.97,0:1:43.98,Default,,0000,0000,0000,,tre onori maggiori, o \nsei carte con almeno due 
Dialogue: 0,0:1:43.98,0:1:44.98,Default,,0000,0000,0000,,onori maggiori. 
Dialogue: 0,0:1:44.98,0:1:45.98,Default,,0000,0000,0000,,E 2 Senz'Atout? 
Dialogue: 0,0:1:45.98,0:1:48.43,Default,,0000,0000,0000,,E' rara e molto \nspecifica: 5-7 punti, 
Dialogue: 0,0:1:48.43,0:1:51.43,Default,,0000,0000,0000,,distribuzione 4-3-3-3, \nalmeno un pezzettino in 
Dialogue: 0,0:1:51.43,0:1:54.44,Default,,0000,0000,0000,,ogni colore, e \nsoprattutto NEGA il possesso di 
Dialogue: 0,0:1:54.44,0:1:55.76,Default,,0000,0000,0000,,un Asso o di due Re. 
Dialogue: 0,0:1:55.76,0:1:58.76,Default,,0000,0000,0000,,E' una risposta che \naiuta l'apertore a contare 
Dialogue: 0,0:1:58.76,0:1:55.94,Default,,0000,0000,0000,,. 
Dialogue: 0,0:1:55.94,0:1:58.72,Default,,0000,0000,0000,,Ora vediamo cosa fa \nl'apertore dopo che il 
Dialogue: 0,0:1:58.72,0:2:1.68,Default,,0000,0000,0000,,compagno ha risposto 2 \nQuadri, la risposta di 
Dialogue: 0,0:2:1.68,0:2:2.18,Default,,0000,0000,0000,,attesa. 
Dialogue: 0,0:2:2.18,0:2:4.96,Default,,0000,0000,0000,,Se l'apertore ridichiara \n2 Senz'Atout, sta 
Dialogue: 0,0:2:4.96,0:2:7.80,Default,,0000,0000,0000,,mostrando una mano \nbilanciata con almeno 23 
Dialogue: 0,0:2:7.80,0:2:8.24,Default,,0000,0000,0000,,punti. 
Dialogue: 0,0:2:8.24,0:2:11.08,Default,,0000,0000,0000,,Questa dichiarazione \ncrea una situazione di 
Dialogue: 0,0:2:11.08,0:2:14.10,Default,,0000,0000,0000,,forzante manche: non \npotete piu' passare sotto 
Dialogue: 0,0:2:14.10,0:2:14.61,Default,,0000,0000,0000,,manche. 
Dialogue: 0,0:2:14.61,0:2:17.70,Default,,0000,0000,0000,,Da qui in poi si \nprosegue esattamente come dopo 
Dialogue: 0,0:2:17.70,0:2:20.66,Default,,0000,0000,0000,,un'apertura di 2 \nSenz'Atout: il compagno puo' 
Dialogue: 0,0:2:20.66,0:2:22.87,Default,,0000,0000,0000,,fare Stayman, Transfer, \neccetera. 
Dialogue: 0,0:2:22.87,0:2:25.96,Default,,0000,0000,0000,,Se l'apertore ridichiara \n2 Cuori o 2 Picche, la 
Dialogue: 0,0:2:25.96,0:2:28.74,Default,,0000,0000,0000,,situazione e' diversa e \nattenzione: NON e' 
Dialogue: 0,0:2:28.74,0:2:29.81,Default,,0000,0000,0000,,forzante manche! 
Dialogue: 0,0:2:29.81,0:2:32.65,Default,,0000,0000,0000,,E' forzante solo fino al \nritorno nel colore 
Dialogue: 0,0:2:32.65,0:2:35.67,Default,,0000,0000,0000,,dell'apertore, cioe' \nfino a 3 Cuori o 3 Picche 
Dialogue: 0,0:2:35.67,0:2:35.80,Default,,0000,0000,0000,,. 
Dialogue: 0,0:2:35.80,0:2:38.64,Default,,0000,0000,0000,,Il rispondente su questa \nridichiarazione ha 
Dialogue: 0,0:2:38.64,0:2:39.58,Default,,0000,0000,0000,,varie opzioni. 
Dialogue: 0,0:2:39.58,0:2:42.61,Default,,0000,0000,0000,,Con fit e speranza di \nportare almeno una presa 
Dialogue: 0,0:2:42.61,0:2:43.68,Default,,0000,0000,0000,,rialza a manche. 
Dialogue: 0,0:2:43.68,0:2:46.52,Default,,0000,0000,0000,,Con fit e ambizioni di \nslam, rialza a 3 nel 
Dialogue: 0,0:2:46.52,0:2:48.41,Default,,0000,0000,0000,,maggiore, che fissa \nl'atout. 
Dialogue: 0,0:2:48.41,0:2:51.44,Default,,0000,0000,0000,,Con una quarta in un \naltro colore, lo mostra a 
Dialogue: 0,0:2:51.44,0:2:54.40,Default,,0000,0000,0000,,livello 2, creando una \ndichiarazione forzante 
Dialogue: 0,0:2:54.40,0:2:55.86,Default,,0000,0000,0000,,fino a 3 nel maggiore. 
Dialogue: 0,0:2:55.86,0:2:58.95,Default,,0000,0000,0000,,Con mano completamente \nnulla, dice 2 Senz'Atout 
Dialogue: 0,0:2:58.95,0:3:1.59,Default,,0000,0000,0000,,come ridichiarazione \nnegativa di attesa. 
Dialogue: 0,0:3:1.59,0:3:4.50,Default,,0000,0000,0000,,Se l'apertore ridichiara \n3 Fiori o 3 Quadri, 
Dialogue: 0,0:3:4.50,0:3:7.59,Default,,0000,0000,0000,,siamo a livello alto e \nla situazione e' scomoda 
Dialogue: 0,0:3:7.59,0:3:7.71,Default,,0000,0000,0000,,. 
Dialogue: 0,0:3:7.71,0:3:10.74,Default,,0000,0000,0000,,Il primo gradino sopra \nl'apertura minore, cioe 
Dialogue: 0,0:3:10.74,0:3:13.83,Default,,0000,0000,0000,,3 Quadri su 3 Fiori, \noppure 3 Cuori su 3 Quadri 
Dialogue: 0,0:3:13.83,0:3:16.79,Default,,0000,0000,0000,,e' la risposta \nconvenzionale negativa: `` Non 
Dialogue: 0,0:3:16.79,0:3:17.49,Default,,0000,0000,0000,,ho niente. 
Dialogue: 0,0:3:17.49,0:3:20.52,Default,,0000,0000,0000,,'' Se l'apertore \nridichiara 3 Cuori o 3 Picche 
Dialogue: 0,0:3:20.52,0:3:23.42,Default,,0000,0000,0000,,a salto, sta mostrando \nun monocolore chiuso: 
Dialogue: 0,0:3:23.42,0:3:26.00,Default,,0000,0000,0000,,impone quel seme come \natout e chiede al 
Dialogue: 0,0:3:26.00,0:3:28.52,Default,,0000,0000,0000,,compagno di mostrare i \nsuoi controlli. 
Dialogue: 0,0:3:28.52,0:3:31.55,Default,,0000,0000,0000,,Un concetto fondamentale \nl'apertura di 2 Fiori 
Dialogue: 0,0:3:31.55,0:3:33.82,Default,,0000,0000,0000,,sancisce il `` possesso \ndel board. 
Dialogue: 0,0:3:33.82,0:3:36.72,Default,,0000,0000,0000,,'' Vuol dire che o \ngiocate voi il contratto, 
Dialogue: 0,0:3:36.72,0:3:39.25,Default,,0000,0000,0000,,oppure gli avversari \ngiocano contrati. 
Dialogue: 0,0:3:39.25,0:3:42.02,Default,,0000,0000,0000,,Se un avversario \ninterviene dopo la vostra 
Dialogue: 0,0:3:42.02,0:3:44.67,Default,,0000,0000,0000,,apertura di 2 Fiori, le \nregole cambiano. 
Dialogue: 0,0:3:44.67,0:3:47.70,Default,,0000,0000,0000,,Il Contro fino a 3 \nPicche compreso e' PUNITIVO 
Dialogue: 0,0:3:47.70,0:3:47.82,Default,,0000,0000,0000,,. 
Dialogue: 0,0:3:47.82,0:3:50.47,Default,,0000,0000,0000,,Se l'intervento e' da 3 \nPicche in su, il 
Dialogue: 0,0:3:50.47,0:3:53.25,Default,,0000,0000,0000,,meccanismo si rovescia: \nContro mostra mano 
Dialogue: 0,0:3:53.25,0:3:56.21,Default,,0000,0000,0000,,nulla, mentre Passo \nindica carte utili per il 
Dialogue: 0,0:3:56.21,0:3:57.54,Default,,0000,0000,0000,,gioco dell'apertore. 
Dialogue: 0,0:3:57.54,0:4:0.56,Default,,0000,0000,0000,,Esempio pratico: hai \nA-K-Q-J-7-6-3 / A / 8-7 / 
Dialogue: 0,0:4:0.56,0:4:1.01,Default,,0000,0000,0000,,A-K-Q. 
Dialogue: 0,0:4:1.01,0:4:1.89,Default,,0000,0000,0000,,Apri 2 Fiori. 
Dialogue: 0,0:4:1.89,0:4:4.92,Default,,0000,0000,0000,,Il compagno ha 8-2 / \nK-J-7-6 / Q-3-2 / 8-7-6-3 
Dialogue: 0,0:4:4.92,0:4:5.04,Default,,0000,0000,0000,,. 
Dialogue: 0,0:4:5.04,0:4:6.87,Default,,0000,0000,0000,,Risponde 2 Quadri( \nattesa). 
Dialogue: 0,0:4:6.87,0:4:9.33,Default,,0000,0000,0000,,Tu dici 3 Picche( \nmonocolore chiuso). 
Dialogue: 0,0:4:9.33,0:4:12.11,Default,,0000,0000,0000,,Il compagno fa 4 Cuori \ncome cue bid( unico 
Dialogue: 0,0:4:12.11,0:4:12.86,Default,,0000,0000,0000,,controllo). 
Dialogue: 0,0:4:12.86,0:4:14.38,Default,,0000,0000,0000,,Tu concludi a 4 Picche. 
Dialogue: 0,0:4:14.38,0:4:15.57,Default,,0000,0000,0000,,Missione compiuta! 
Dialogue: 0,0:4:15.57,0:4:16.52,Default,,0000,0000,0000,,Alla prossima! 
