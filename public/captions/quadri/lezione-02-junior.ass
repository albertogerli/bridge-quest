Dialogue: 0,0:0:0.00,0:0:0.37,Default,,0000,0000,0000,,Ciao! 
Dialogue: 0,0:0:0.37,0:0:3.17,Default,,0000,0000,0000,,Oggi impariamo qualcosa \ndi super importante: 
Dialogue: 0,0:0:3.17,0:0:6.16,Default,,0000,0000,0000,,come decidere se aprire \nla dichiarazione quando 
Dialogue: 0,0:0:6.16,0:0:9.14,Default,,0000,0000,0000,,hai una mano che sembra \nabbastanza forte ma non 
Dialogue: 0,0:0:9.14,0:0:9.87,Default,,0000,0000,0000,,sei sicuro. 
Dialogue: 0,0:0:9.87,0:0:12.86,Default,,0000,0000,0000,,E parliamo anche delle \naperture di barrage, che 
Dialogue: 0,0:0:12.86,0:0:14.69,Default,,0000,0000,0000,,sono una mossa davvero \nfiga! 
Dialogue: 0,0:0:14.69,0:0:17.31,Default,,0000,0000,0000,,Partiamo dalla \nsituazione piu comune: hai 
Dialogue: 0,0:0:17.31,0:0:18.96,Default,,0000,0000,0000,,contato i punti e hai 11 . 
Dialogue: 0,0:0:18.96,0:0:21.70,Default,,0000,0000,0000,,Nel Corso Fiori hai \nimparato che servono 12 
Dialogue: 0,0:0:21.70,0:0:22.80,Default,,0000,0000,0000,,punti per aprire. 
Dialogue: 0,0:0:22.80,0:0:25.17,Default,,0000,0000,0000,,Ma 11 e cosi vicino a 12 \nche viene la 
Dialogue: 0,0:0:25.17,0:0:26.27,Default,,0000,0000,0000,,tentazione, vero? 
Dialogue: 0,0:0:26.27,0:0:29.26,Default,,0000,0000,0000,,Ecco, non tutte le mani \nda 11 punti sono uguali 
Dialogue: 0,0:0:29.26,0:0:29.38,Default,,0000,0000,0000,,. 
Dialogue: 0,0:0:29.38,0:0:32.12,Default,,0000,0000,0000,,Alcune sono belle e puoi \naprire, altre sono 
Dialogue: 0,0:0:32.12,0:0:33.58,Default,,0000,0000,0000,,pessime e devi passare. 
Dialogue: 0,0:0:33.58,0:0:35.17,Default,,0000,0000,0000,,Come fai a distinguerle ? 
Dialogue: 0,0:0:35.17,0:0:36.21,Default,,0000,0000,0000,,Con i 5 difetti! 
Dialogue: 0,0:0:36.21,0:0:38.52,Default,,0000,0000,0000,,Primo difetto: poche \ncarte di testa. 
Dialogue: 0,0:0:38.52,0:0:41.51,Default,,0000,0000,0000,,Le carte di testa sono \nAssi e Re: vincono prese 
Dialogue: 0,0:0:41.51,0:0:42.54,Default,,0000,0000,0000,,sicure e veloci. 
Dialogue: 0,0:0:42.54,0:0:45.47,Default,,0000,0000,0000,,Donna, Fante e Dieci \nsono piu lente e incerte. 
Dialogue: 0,0:0:45.47,0:0:48.40,Default,,0000,0000,0000,,Se i tuoi 11 punti \nvengono da un Asso, un Re e 
Dialogue: 0,0:0:48.40,0:0:51.38,Default,,0000,0000,0000,,una Donna, e molto \nmeglio che se vengono da tre 
Dialogue: 0,0:0:51.38,0:0:53.15,Default,,0000,0000,0000,,Donne, un Fante e un \nDieci. 
Dialogue: 0,0:0:53.15,0:0:55.95,Default,,0000,0000,0000,,Pensa cosi: Asso e Re ti \ndanno prese sicure, 
Dialogue: 0,0:0:55.95,0:0:58.33,Default,,0000,0000,0000,,Donna e Fante ti danno \nsolo speranze. 
Dialogue: 0,0:0:58.33,0:1:0.22,Default,,0000,0000,0000,,Secondo difetto: mano \nimpura. 
Dialogue: 0,0:1:0.22,0:1:3.08,Default,,0000,0000,0000,,Una mano pura ha gli \nonori nei colori lunghi, 
Dialogue: 0,0:1:3.08,0:1:4.91,Default,,0000,0000,0000,,dove possono produrre \nprese. 
Dialogue: 0,0:1:4.91,0:1:7.84,Default,,0000,0000,0000,,Una mano impura ha gli \nonori sparsi nei colori 
Dialogue: 0,0:1:7.84,0:1:10.34,Default,,0000,0000,0000,,corti, dove non servono \nquasi a niente. 
Dialogue: 0,0:1:10.34,0:1:13.32,Default,,0000,0000,0000,,Se hai Re-Donna nelle \ntue cinque Quadri, quegli 
Dialogue: 0,0:1:13.32,0:1:14.73,Default,,0000,0000,0000,,onori lavorano per te. 
Dialogue: 0,0:1:14.73,0:1:17.41,Default,,0000,0000,0000,,Ma se hai Re-Donna nelle \ntue due Picche, e 
Dialogue: 0,0:1:17.41,0:1:20.21,Default,,0000,0000,0000,,difficile che producano \nprese con cosi poche 
Dialogue: 0,0:1:20.21,0:1:21.37,Default,,0000,0000,0000,,carte di appoggio. 
Dialogue: 0,0:1:21.37,0:1:23.81,Default,,0000,0000,0000,,Terzo difetto: colori \nnon competitivi. 
Dialogue: 0,0:1:23.81,0:1:26.73,Default,,0000,0000,0000,,Se i tuoi colori lunghi \nnon hanno nobili, cioe 
Dialogue: 0,0:1:26.73,0:1:29.42,Default,,0000,0000,0000,,Picche o Cuori, sara \ndifficile trovare una 
Dialogue: 0,0:1:29.42,0:1:29.90,Default,,0000,0000,0000,,manche. 
Dialogue: 0,0:1:29.90,0:1:32.83,Default,,0000,0000,0000,,Le manche a colore si \ngiocano quasi sempre nei 
Dialogue: 0,0:1:32.83,0:1:35.75,Default,,0000,0000,0000,,nobili, e se non li hai \ndevi sperare nel Senza 
Dialogue: 0,0:1:35.75,0:1:37.22,Default,,0000,0000,0000,,che richiede piu punti. 
Dialogue: 0,0:1:37.22,0:1:39.66,Default,,0000,0000,0000,,Quarto difetto: \nposizione sfavorevole. 
Dialogue: 0,0:1:39.66,0:1:42.40,Default,,0000,0000,0000,,In prima e quarta \nposizione, devi avere una 
Dialogue: 0,0:1:42.40,0:1:43.80,Default,,0000,0000,0000,,mano piena per aprire. 
Dialogue: 0,0:1:43.80,0:1:46.73,Default,,0000,0000,0000,,Solo in terza posizione \nquando il tuo compagno 
Dialogue: 0,0:1:46.73,0:1:49.53,Default,,0000,0000,0000,,ha gia passato e sai che \nnon ha molti punti, 
Dialogue: 0,0:1:49.53,0:1:52.46,Default,,0000,0000,0000,,puoi permetterti di \naprire un po' piu leggero. 
Dialogue: 0,0:1:52.46,0:1:55.38,Default,,0000,0000,0000,,Quinto difetto: pessima \nseconda dichiarazione. 
Dialogue: 0,0:1:55.38,0:1:58.31,Default,,0000,0000,0000,,Prima di aprire, \nimmagina cosa succedera dopo. 
Dialogue: 0,0:1:58.31,0:2:1.17,Default,,0000,0000,0000,,Se il tuo compagno \nrisponde in un colore e tu 
Dialogue: 0,0:2:1.17,0:2:3.91,Default,,0000,0000,0000,,non sai cosa dire, forse \nla mano non era da 
Dialogue: 0,0:2:3.91,0:2:2.21,Default,,0000,0000,0000,,aprire! 
Dialogue: 0,0:2:2.21,0:2:5.01,Default,,0000,0000,0000,,Ed ecco la regola magica \nse la tua mano da 11 
Dialogue: 0,0:2:5.01,0:2:7.81,Default,,0000,0000,0000,,punti ha almeno 2 di \nquesti 5 difetti, passa! 
Dialogue: 0,0:2:7.81,0:2:8.53,Default,,0000,0000,0000,,Non aprire. 
Dialogue: 0,0:2:8.53,0:2:11.33,Default,,0000,0000,0000,,I difetti si sommano e \nrendono la mano troppo 
Dialogue: 0,0:2:11.33,0:2:13.59,Default,,0000,0000,0000,,debole per iniziare la \nconversazione 
Dialogue: 0,0:2:13.59,0:2:14.43,Default,,0000,0000,0000,,dichiarativa. 
Dialogue: 0,0:2:14.43,0:2:15.68,Default,,0000,0000,0000,,Facciamo un esempio. 
Dialogue: 0,0:2:15.68,0:2:18.48,Default,,0000,0000,0000,,Hai: \nDonna-piccola-piccola-pi ccola a Picche, 
Dialogue: 0,0:2:18.48,0:2:20.74,Default,,0000,0000,0000,,Re a Cuori, \nDonna-Fante-piccola-picc 
Dialogue: 0,0:2:20.74,0:2:23.43,Default,,0000,0000,0000,,ola-piccola a Quadri, \nDonna-Fante-piccola a 
Dialogue: 0,0:2:23.43,0:2:23.84,Default,,0000,0000,0000,,Fiori. 
Dialogue: 0,0:2:23.84,0:2:26.35,Default,,0000,0000,0000,,Sono 11 punti, ma guarda \nquanti difetti! 
Dialogue: 0,0:2:26.35,0:2:29.21,Default,,0000,0000,0000,,Poche carte di testa, \nniente Assi e un solo Re 
Dialogue: 0,0:2:29.21,0:2:29.32,Default,,0000,0000,0000,,. 
Dialogue: 0,0:2:29.32,0:2:32.07,Default,,0000,0000,0000,,Mano impura, il Re di \nCuori e su un singolo. 
Dialogue: 0,0:2:32.07,0:2:34.27,Default,,0000,0000,0000,,E nessun colore nobile \ncompetitivo. 
Dialogue: 0,0:2:34.27,0:2:37.07,Default,,0000,0000,0000,,Tre difetti su cinque: \nquesta mano va passata 
Dialogue: 0,0:2:37.07,0:2:38.03,Default,,0000,0000,0000,,senza pensarci! 
Dialogue: 0,0:2:38.03,0:2:40.95,Default,,0000,0000,0000,,Ora passiamo alle \naperture di barrage, che sono 
Dialogue: 0,0:2:40.95,0:2:42.08,Default,,0000,0000,0000,,tutt'altra storia. 
Dialogue: 0,0:2:42.08,0:2:44.82,Default,,0000,0000,0000,,Un barrage e un'apertura \na livello 3 o 4 che 
Dialogue: 0,0:2:44.82,0:2:47.50,Default,,0000,0000,0000,,dice al mondo: ho un \ncolore lunghissimo con 
Dialogue: 0,0:2:47.50,0:2:50.42,Default,,0000,0000,0000,,almeno sette carte buone \nfaccio circa tre prese 
Dialogue: 0,0:2:50.42,0:2:53.10,Default,,0000,0000,0000,,meno di quelle che \ndichiaro, e in qualsiasi 
Dialogue: 0,0:2:53.10,0:2:55.25,Default,,0000,0000,0000,,altro contratto non \nfaccio niente. 
Dialogue: 0,0:2:55.25,0:2:57.99,Default,,0000,0000,0000,,Per fare un barrage \nservono tre cose: almeno 
Dialogue: 0,0:2:57.99,0:3:0.73,Default,,0000,0000,0000,,sette carte con onori \nnel colore, non piu di 
Dialogue: 0,0:3:0.73,0:3:3.65,Default,,0000,0000,0000,,una carta alta esterna \nal colore, e la capacita 
Dialogue: 0,0:3:3.65,0:3:6.45,Default,,0000,0000,0000,,di fare un certo numero \ndi prese solo col tuo 
Dialogue: 0,0:3:6.45,0:3:6.93,Default,,0000,0000,0000,,colore. 
Dialogue: 0,0:3:6.93,0:3:9.67,Default,,0000,0000,0000,,Se apri 3 Picche, stai \ndicendo che fai circa 
Dialogue: 0,0:3:9.67,0:3:11.40,Default,,0000,0000,0000,,sei prese a Picche e \nbasta. 
Dialogue: 0,0:3:11.40,0:3:13.72,Default,,0000,0000,0000,,Esempio: hai \nRe-Donna-Fante-piccola-p 
Dialogue: 0,0:3:13.72,0:3:15.75,Default,,0000,0000,0000,,iccola-piccola-piccola a \nPicche, 
Dialogue: 0,0:3:15.75,0:3:18.31,Default,,0000,0000,0000,,piccola-piccola a Cuori \npiccola-piccola a 
Dialogue: 0,0:3:18.31,0:3:20.22,Default,,0000,0000,0000,,Quadri, Fante-piccola a \nFiori. 
Dialogue: 0,0:3:20.22,0:3:23.02,Default,,0000,0000,0000,,Sette Picche con \nRe-Donna-Fante in testa, una 
Dialogue: 0,0:3:23.02,0:3:24.81,Default,,0000,0000,0000,,sola carta discreta \nesterna. 
Dialogue: 0,0:3:24.81,0:3:25.70,Default,,0000,0000,0000,,Apri 3 Picche! 
Dialogue: 0,0:3:25.70,0:3:28.62,Default,,0000,0000,0000,,Ma attenzione: se hai \ndue Assi o due Re esterni 
Dialogue: 0,0:3:28.62,0:3:31.00,Default,,0000,0000,0000,,la mano e troppo forte \nper un barrage. 
Dialogue: 0,0:3:31.00,0:3:32.79,Default,,0000,0000,0000,,Con \nAsso-Donna-Fante-piccola 
Dialogue: 0,0:3:32.79,0:3:34.94,Default,,0000,0000,0000,,-piccola-piccola-piccola \na Picche, 
Dialogue: 0,0:3:34.94,0:3:37.50,Default,,0000,0000,0000,,piccola-piccola a Cuori \npiccola-piccola a 
Dialogue: 0,0:3:37.50,0:3:40.36,Default,,0000,0000,0000,,Quadri, Asso-piccola a \nFiori, hai troppa forza 
Dialogue: 0,0:3:40.36,0:3:40.90,Default,,0000,0000,0000,,esterna. 
Dialogue: 0,0:3:40.90,0:3:42.62,Default,,0000,0000,0000,,Apri di 1 Picche, non di \n3. 
Dialogue: 0,0:3:42.62,0:3:45.13,Default,,0000,0000,0000,,E la regola d'oro del \nbarrage: chi fa un 
Dialogue: 0,0:3:45.13,0:3:47.81,Default,,0000,0000,0000,,barrage poi va al bar a \nprendersi un caffe! 
Dialogue: 0,0:3:47.81,0:3:50.61,Default,,0000,0000,0000,,Significa che dopo aver \nfatto il barrage, non 
Dialogue: 0,0:3:50.61,0:3:51.98,Default,,0000,0000,0000,,prendi piu iniziative. 
Dialogue: 0,0:3:51.98,0:3:54.90,Default,,0000,0000,0000,,Hai detto tutto quello \nche avevi da dire con la 
Dialogue: 0,0:3:54.90,0:3:56.15,Default,,0000,0000,0000,,prima dichiarazione. 
Dialogue: 0,0:3:56.15,0:3:58.30,Default,,0000,0000,0000,,Adesso tocca al compagno \ndecidere. 
Dialogue: 0,0:3:58.30,0:4:1.22,Default,,0000,0000,0000,,Ora parliamo delle mani \n6-5, cioe quelle con un 
Dialogue: 0,0:4:1.22,0:4:3.48,Default,,0000,0000,0000,,colore di sei carte e \nuno di cinque. 
Dialogue: 0,0:4:3.48,0:4:5.87,Default,,0000,0000,0000,,Sono mani potentissime \nma difficili da 
Dialogue: 0,0:4:5.87,0:4:8.79,Default,,0000,0000,0000,,descrivere perche \nservono tre dichiarazioni per 
Dialogue: 0,0:4:8.79,0:4:9.98,Default,,0000,0000,0000,,mostrarle entrambe. 
Dialogue: 0,0:4:9.98,0:4:12.84,Default,,0000,0000,0000,,Se la mano non e \nfortissima, trattala come una 
Dialogue: 0,0:4:12.84,0:4:15.28,Default,,0000,0000,0000,,5-5: apri nel colore di \nrango maggiore. 
Dialogue: 0,0:4:15.28,0:4:18.14,Default,,0000,0000,0000,,Alla prossima lezione \nscopriremo i segreti del 
Dialogue: 0,0:4:18.14,0:4:20.76,Default,,0000,0000,0000,,gioco con l'atout, i \ntempi e il controllo. 
Dialogue: 0,0:4:20.76,0:4:21.84,Default,,0000,0000,0000,,Sara emozionante! 
