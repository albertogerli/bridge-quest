Dialogue: 0,0:0:0.00,0:0:0.37,Default,,0000,0000,0000,,Ciao! 
Dialogue: 0,0:0:0.37,0:0:2.01,Default,,0000,0000,0000,,Bentornato a BridgeQuest ! 
Dialogue: 0,0:0:2.01,0:0:4.70,Default,,0000,0000,0000,,Oggi parliamo di un \nargomento che ti fara' 
Dialogue: 0,0:0:4.70,0:0:7.39,Default,,0000,0000,0000,,diventare molto piu' \nforte nel gioco della 
Dialogue: 0,0:0:7.39,0:0:10.38,Default,,0000,0000,0000,,carta: come muovere le \nfigure nei colori bucati 
Dialogue: 0,0:0:10.38,0:0:10.50,Default,,0000,0000,0000,,. 
Dialogue: 0,0:0:10.50,0:0:13.31,Default,,0000,0000,0000,,Un colore bucato e' un \ncolore dove hai degli 
Dialogue: 0,0:0:13.31,0:0:15.26,Default,,0000,0000,0000,,onori ma ti mancano dei \npezzi. 
Dialogue: 0,0:0:15.26,0:0:18.13,Default,,0000,0000,0000,,Per esempio hai l'Asso e \nla Donna ma ti manca 
Dialogue: 0,0:0:18.13,0:0:18.55,Default,,0000,0000,0000,,il Re. 
Dialogue: 0,0:0:18.55,0:0:21.24,Default,,0000,0000,0000,,Oppure hai il Re e il \nFante ma ti manca la 
Dialogue: 0,0:0:21.24,0:0:21.67,Default,,0000,0000,0000,,Donna. 
Dialogue: 0,0:0:21.67,0:0:24.41,Default,,0000,0000,0000,,Come fai a prendere il \nmassimo delle prese? 
Dialogue: 0,0:0:24.41,0:0:26.86,Default,,0000,0000,0000,,C' e' un principio \nuniversale che devi 
Dialogue: 0,0:0:26.86,0:0:29.48,Default,,0000,0000,0000,,ricordare: quando \nentrambe le parti hanno 
Dialogue: 0,0:0:29.48,0:0:32.29,Default,,0000,0000,0000,,interesse a muovere un \ncolore, chi muove per 
Dialogue: 0,0:0:32.29,0:0:34.55,Default,,0000,0000,0000,,primo e' quasi sempre \nsvantaggiato! 
Dialogue: 0,0:0:34.55,0:0:37.35,Default,,0000,0000,0000,,E' come nel gioco del \npollo: chi fa la prima 
Dialogue: 0,0:0:37.35,0:0:38.76,Default,,0000,0000,0000,,mossa rischia di piu'. 
Dialogue: 0,0:0:38.76,0:0:39.31,Default,,0000,0000,0000,,Perche'? 
Dialogue: 0,0:0:39.31,0:0:41.93,Default,,0000,0000,0000,,Perche' ogni giocatore \n`` marca a uomo '' 
Dialogue: 0,0:0:41.93,0:0:43.76,Default,,0000,0000,0000,,l'avversario che lo \nprecede. 
Dialogue: 0,0:0:43.76,0:0:46.51,Default,,0000,0000,0000,,Se giochi una carta, \nl'avversario che viene 
Dialogue: 0,0:0:46.51,0:0:49.13,Default,,0000,0000,0000,,dopo di te puo' vedere \ncosa hai giocato e 
Dialogue: 0,0:0:49.13,0:0:50.84,Default,,0000,0000,0000,,decidere come \ncomportarsi. 
Dialogue: 0,0:0:50.84,0:0:51.51,Default,,0000,0000,0000,,Bello, no? 
Dialogue: 0,0:0:51.51,0:0:54.38,Default,,0000,0000,0000,,Da questa idea nasce una \nregola fondamentale: 
Dialogue: 0,0:0:54.38,0:0:57.37,Default,,0000,0000,0000,,in seconda posizione, \ncioe' quando l'avversario 
Dialogue: 0,0:0:57.37,0:1:0.30,Default,,0000,0000,0000,,davanti a te ha appena \ngiocato, gioca piccola! 
Dialogue: 0,0:1:0.30,0:1:2.56,Default,,0000,0000,0000,,Piccola su piccola, \nonore su onore. 
Dialogue: 0,0:1:2.56,0:1:5.37,Default,,0000,0000,0000,,Se l'avversario gioca \nuna cartina, tu giochi 
Dialogue: 0,0:1:5.37,0:1:6.16,Default,,0000,0000,0000,,una cartina. 
Dialogue: 0,0:1:6.16,0:1:8.91,Default,,0000,0000,0000,,Se l'avversario gioca un \nonore, allora puoi 
Dialogue: 0,0:1:8.91,0:1:10.86,Default,,0000,0000,0000,,mettere un onore per \ncoprirlo. 
Dialogue: 0,0:1:10.86,0:1:11.47,Default,,0000,0000,0000,,Semplice! 
Dialogue: 0,0:1:11.47,0:1:13.67,Default,,0000,0000,0000,,Ora vediamo degli esempi \nconcreti. 
Dialogue: 0,0:1:13.67,0:1:16.60,Default,,0000,0000,0000,,Immagina di avere Asso, \nDonna, Cinque, Quattro 
Dialogue: 0,0:1:16.60,0:1:19.53,Default,,0000,0000,0000,,da una parte e Fante, \nSei, Tre, Due dall'altra 
Dialogue: 0,0:1:19.53,0:1:19.65,Default,,0000,0000,0000,,. 
Dialogue: 0,0:1:19.65,0:1:20.63,Default,,0000,0000,0000,,Ti manca il Re. 
Dialogue: 0,0:1:20.63,0:1:22.03,Default,,0000,0000,0000,,Come prendi due prese? 
Dialogue: 0,0:1:22.03,0:1:24.35,Default,,0000,0000,0000,,Devi giocare piccola \nverso la Donna! 
Dialogue: 0,0:1:24.35,0:1:26.97,Default,,0000,0000,0000,,Se il Re e' nella \nposizione giusta, cioe' 
Dialogue: 0,0:1:26.97,0:1:29.97,Default,,0000,0000,0000,,davanti alla Donna, la \ntua Donna vince la presa 
Dialogue: 0,0:1:29.97,0:1:30.09,Default,,0000,0000,0000,,. 
Dialogue: 0,0:1:30.09,0:1:32.90,Default,,0000,0000,0000,,Poi torni dall'altra \nparte e giochi di nuovo 
Dialogue: 0,0:1:32.90,0:1:34.24,Default,,0000,0000,0000,,piccola verso l'Asso. 
Dialogue: 0,0:1:34.24,0:1:36.31,Default,,0000,0000,0000,,Fantastico, hai preso \ndue prese! 
Dialogue: 0,0:1:36.31,0:1:39.00,Default,,0000,0000,0000,,Ma attenzione: non \niniziare MAI col Fante! 
Dialogue: 0,0:1:39.00,0:1:41.93,Default,,0000,0000,0000,,Questa e' una delle \nregole piu' importanti che 
Dialogue: 0,0:1:41.93,0:1:42.60,Default,,0000,0000,0000,,imparerai. 
Dialogue: 0,0:1:42.60,0:1:45.29,Default,,0000,0000,0000,,Il Fante senza il Dieci \ne' come un soldato 
Dialogue: 0,0:1:45.29,0:1:46.08,Default,,0000,0000,0000,,senza scudo. 
Dialogue: 0,0:1:46.08,0:1:49.01,Default,,0000,0000,0000,,Se giochi il Fante e \nl'avversario lo copre col 
Dialogue: 0,0:1:49.01,0:1:51.94,Default,,0000,0000,0000,,Re, hai perso sia il \nFante che la possibilita' 
Dialogue: 0,0:1:51.94,0:1:53.10,Default,,0000,0000,0000,,di fare l'impasse. 
Dialogue: 0,0:1:53.10,0:1:55.91,Default,,0000,0000,0000,,Chi gioca il Fante senza \navere il Dieci deve 
Dialogue: 0,0:1:55.91,0:1:58.90,Default,,0000,0000,0000,,stare in ginocchio sui \nceci, come si dice tra i 
Dialogue: 0,0:1:58.90,0:1:56.76,Default,,0000,0000,0000,,bridgisti! 
Dialogue: 0,0:1:56.76,0:1:59.90,Default,,0000,0000,0000,,Adesso impariamo \nun'altra cosa importantissima 
Dialogue: 0,0:1:59.90,0:2:1.15,Default,,0000,0000,0000,,il colpo di sonda. 
Dialogue: 0,0:2:1.15,0:2:2.98,Default,,0000,0000,0000,,E' una mossa da \ndetective! 
Dialogue: 0,0:2:2.98,0:2:5.86,Default,,0000,0000,0000,,Quando hai una \ncombinazione come Asso, Re, 
Dialogue: 0,0:2:5.86,0:2:9.07,Default,,0000,0000,0000,,Fante, Dieci da una \nparte e Otto, Sette, Cinque 
Dialogue: 0,0:2:9.07,0:2:11.43,Default,,0000,0000,0000,,Due dall'altra, ti manca \nla Donna. 
Dialogue: 0,0:2:11.43,0:2:12.87,Default,,0000,0000,0000,,Come fai a prenderla? 
Dialogue: 0,0:2:12.87,0:2:16.08,Default,,0000,0000,0000,,Il colpo di sonda \nfunziona cosi': prima incassi 
Dialogue: 0,0:2:16.08,0:2:18.90,Default,,0000,0000,0000,,uno degli onori alti, \nper esempio l'Asso. 
Dialogue: 0,0:2:18.90,0:2:20.80,Default,,0000,0000,0000,,Se la Donna cade, \nperfetto! 
Dialogue: 0,0:2:20.80,0:2:23.94,Default,,0000,0000,0000,,Se non cade, fai \nl'impasse al giro successivo, 
Dialogue: 0,0:2:23.94,0:2:25.65,Default,,0000,0000,0000,,giocando verso il Fante . 
Dialogue: 0,0:2:25.65,0:2:28.85,Default,,0000,0000,0000,,In questo modo catturi \nla Donna sia se e' secca 
Dialogue: 0,0:2:28.85,0:2:31.41,Default,,0000,0000,0000,,sia se e' seconda o \nterza in impasse. 
Dialogue: 0,0:2:31.41,0:2:34.62,Default,,0000,0000,0000,,E' come tendere una \ntrappola con due uscite: la 
Dialogue: 0,0:2:34.62,0:2:36.32,Default,,0000,0000,0000,,preda non puo' scappare ! 
Dialogue: 0,0:2:36.32,0:2:39.47,Default,,0000,0000,0000,,Ma attenzione: il colpo \ndi sonda funziona solo 
Dialogue: 0,0:2:39.47,0:2:42.48,Default,,0000,0000,0000,,quando hai una \ndistribuzione tipo 4/4 o 5/3. 
Dialogue: 0,0:2:42.48,0:2:45.43,Default,,0000,0000,0000,,Se hai 6 carte da una \nparte e 2 dall'altra, 
Dialogue: 0,0:2:45.43,0:2:48.57,Default,,0000,0000,0000,,tipo Asso, Re, Fante, \nQuattro, Tre, Due e Sei, 
Dialogue: 0,0:2:48.57,0:2:50.99,Default,,0000,0000,0000,,Cinque, NON fare il \ncolpo di sonda! 
Dialogue: 0,0:2:50.99,0:2:54.01,Default,,0000,0000,0000,,In quel caso la Donna \npotrebbe essere quarta 
Dialogue: 0,0:2:54.01,0:2:56.82,Default,,0000,0000,0000,,nell'avversario e il \ncolpo di sonda te la 
Dialogue: 0,0:2:56.82,0:2:57.94,Default,,0000,0000,0000,,farebbe perdere. 
Dialogue: 0,0:2:57.94,0:2:59.77,Default,,0000,0000,0000,,Vai diretto con \nl'impasse. 
Dialogue: 0,0:2:59.77,0:3:2.85,Default,,0000,0000,0000,,Ora parliamo della \nregola aurea dell'impasse. 
Dialogue: 0,0:3:2.85,0:3:4.81,Default,,0000,0000,0000,,E' facilissima da \nricordare. 
Dialogue: 0,0:3:4.81,0:3:8.02,Default,,0000,0000,0000,,Quando ti manca un onore \npiu' due o tre cartine 
Dialogue: 0,0:3:8.02,0:3:9.01,Default,,0000,0000,0000,,fai l'impasse. 
Dialogue: 0,0:3:9.01,0:3:12.02,Default,,0000,0000,0000,,Quando ti manca un onore \ne una sola cartina: 
Dialogue: 0,0:3:12.02,0:3:14.90,Default,,0000,0000,0000,,batti in testa, cioe' \ngioca gli onori alti 
Dialogue: 0,0:3:14.90,0:3:16.15,Default,,0000,0000,0000,,sperando che cada. 
Dialogue: 0,0:3:16.15,0:3:18.18,Default,,0000,0000,0000,,E quando manca solo la \nDonna? 
Dialogue: 0,0:3:18.18,0:3:21.32,Default,,0000,0000,0000,,Se hai 9 o piu' carte in \nlinea, batti in testa 
Dialogue: 0,0:3:21.32,0:3:21.45,Default,,0000,0000,0000,,. 
Dialogue: 0,0:3:21.45,0:3:23.81,Default,,0000,0000,0000,,Se ne hai 8 o meno, fai \nl'impasse. 
Dialogue: 0,0:3:23.81,0:3:24.20,Default,,0000,0000,0000,,Vedi? 
Dialogue: 0,0:3:24.20,0:3:24.86,Default,,0000,0000,0000,,Semplice! 
Dialogue: 0,0:3:24.86,0:3:27.54,Default,,0000,0000,0000,,Parliamo anche dei \ngradini di ingresso. 
Dialogue: 0,0:3:27.54,0:3:30.69,Default,,0000,0000,0000,,Immagina di avere Dieci \nOtto, Tre da una parte 
Dialogue: 0,0:3:30.69,0:3:33.83,Default,,0000,0000,0000,,e Asso, Donna, Fante, \nNove, Cinque dall'altra. 
Dialogue: 0,0:3:33.83,0:3:36.58,Default,,0000,0000,0000,,Vuoi catturare il Re \nanche se e' quarto. 
Dialogue: 0,0:3:36.58,0:3:37.24,Default,,0000,0000,0000,,Come fai? 
Dialogue: 0,0:3:37.24,0:3:38.41,Default,,0000,0000,0000,,Inizi con l'Otto! 
Dialogue: 0,0:3:38.41,0:3:41.10,Default,,0000,0000,0000,,Se il Re non copre, \nsuperi con il Nove. 
Dialogue: 0,0:3:41.10,0:3:43.98,Default,,0000,0000,0000,,Poi torni col Dieci, e \nse il Re non copre, 
Dialogue: 0,0:3:43.98,0:3:45.16,Default,,0000,0000,0000,,superi col Fante. 
Dialogue: 0,0:3:45.16,0:3:47.65,Default,,0000,0000,0000,,E infine giochi il Tre \nper la Donna. 
Dialogue: 0,0:3:47.65,0:3:50.53,Default,,0000,0000,0000,,In questo modo puoi \nripetere l'impasse tre 
Dialogue: 0,0:3:50.53,0:3:53.68,Default,,0000,0000,0000,,volte usando le carte \nintermedie come gradini, 
Dialogue: 0,0:3:53.68,0:3:56.03,Default,,0000,0000,0000,,senza bisogno di \ningressi esterni. 
Dialogue: 0,0:3:56.03,0:3:56.89,Default,,0000,0000,0000,,Geniale, no? 
Dialogue: 0,0:3:56.89,0:3:59.24,Default,,0000,0000,0000,,Ultimo concetto: i casi \ndisperati. 
Dialogue: 0,0:3:59.24,0:4:2.26,Default,,0000,0000,0000,,A volte sei nella \nsituazione in cui non puoi 
Dialogue: 0,0:4:2.26,0:4:5.20,Default,,0000,0000,0000,,fare l'impasse perche' \nnon hai la posizione 
Dialogue: 0,0:4:5.20,0:4:5.73,Default,,0000,0000,0000,,giusta. 
Dialogue: 0,0:4:5.73,0:4:8.81,Default,,0000,0000,0000,,In quel caso, l'unica \nsperanza e' che l'onore 
Dialogue: 0,0:4:8.81,0:4:10.12,Default,,0000,0000,0000,,mancante sia secco. 
Dialogue: 0,0:4:10.12,0:4:13.06,Default,,0000,0000,0000,,Per esempio hai Asso, \nDonna, Fante, Dieci e 
Dialogue: 0,0:4:13.06,0:4:16.21,Default,,0000,0000,0000,,tante cartine dalla tua \nparte e una sola carta 
Dialogue: 0,0:4:16.21,0:4:16.99,Default,,0000,0000,0000,,dall'altra. 
Dialogue: 0,0:4:16.99,0:4:19.68,Default,,0000,0000,0000,,Non puoi fare l'impasse \nverso la Donna. 
Dialogue: 0,0:4:19.68,0:4:22.56,Default,,0000,0000,0000,,Allora tira l'Asso e \nspera che il Re cada! 
Dialogue: 0,0:4:22.56,0:4:25.51,Default,,0000,0000,0000,,E' un caso disperato, ma \nnel bridge a volte 
Dialogue: 0,0:4:25.51,0:4:27.28,Default,,0000,0000,0000,,bisogna essere ottimisti . 
Dialogue: 0,0:4:27.28,0:4:29.57,Default,,0000,0000,0000,,Ci vediamo alla prossima \nlezione! 
