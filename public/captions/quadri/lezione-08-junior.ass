Dialogue: 0,0:0:0.00,0:0:0.36,Default,,0000,0000,0000,,Ciao! 
Dialogue: 0,0:0:0.36,0:0:1.97,Default,,0000,0000,0000,,Bentornato a BridgeQuest ! 
Dialogue: 0,0:0:1.97,0:0:4.78,Default,,0000,0000,0000,,Oggi parliamo di un \nargomento che ti aiutera' 
Dialogue: 0,0:0:4.78,0:0:7.65,Default,,0000,0000,0000,,tantissimo nella \ndichiarazione: l'accostamento 
Dialogue: 0,0:0:7.65,0:0:8.25,Default,,0000,0000,0000,,a manche. 
Dialogue: 0,0:0:8.25,0:0:11.00,Default,,0000,0000,0000,,Sai quando tu e il \ncompagno avete abbastanza 
Dialogue: 0,0:0:11.00,0:0:13.75,Default,,0000,0000,0000,,punti per la manche ma \nnon riuscite a capire 
Dialogue: 0,0:0:13.75,0:0:14.58,Default,,0000,0000,0000,,dove giocare? 
Dialogue: 0,0:0:14.58,0:0:16.97,Default,,0000,0000,0000,,Bene, oggi impariamo gli \nstrumenti per 
Dialogue: 0,0:0:16.97,0:0:18.65,Default,,0000,0000,0000,,risolvere questo \nproblema! 
Dialogue: 0,0:0:18.65,0:0:21.40,Default,,0000,0000,0000,,Partiamo da due concetti \nimportantissimi: il 
Dialogue: 0,0:0:21.40,0:0:23.43,Default,,0000,0000,0000,,Terzo colore e il Quarto \ncolore. 
Dialogue: 0,0:0:23.43,0:0:26.36,Default,,0000,0000,0000,,Immagina che la licita \nsia andata cosi': il tuo 
Dialogue: 0,0:0:26.36,0:0:29.23,Default,,0000,0000,0000,,compagno ha aperto di 1 \nFiori, tu hai risposto 
Dialogue: 0,0:0:29.23,0:0:31.32,Default,,0000,0000,0000,,1 Cuori, e lui ha detto \n1 Picche. 
Dialogue: 0,0:0:31.32,0:0:34.01,Default,,0000,0000,0000,,Ora ci sono due colori \nancora non detti: le 
Dialogue: 0,0:0:34.01,0:0:35.68,Default,,0000,0000,0000,,Quadri e ... beh, \ndipende! 
Dialogue: 0,0:0:35.68,0:0:38.61,Default,,0000,0000,0000,,Se dici un nuovo colore \npotresti star usando il 
Dialogue: 0,0:0:38.61,0:0:40.94,Default,,0000,0000,0000,,Terzo colore oppure il \nQuarto colore. 
Dialogue: 0,0:0:40.94,0:0:42.85,Default,,0000,0000,0000,,La differenza e' \nfondamentale. 
Dialogue: 0,0:0:42.85,0:0:45.60,Default,,0000,0000,0000,,Il Terzo colore e' \nquando ci sono DUE colori 
Dialogue: 0,0:0:45.60,0:0:48.11,Default,,0000,0000,0000,,disponibili da dire, e \ntu ne scegli uno. 
Dialogue: 0,0:0:48.11,0:0:50.92,Default,,0000,0000,0000,,Per esempio: dopo 1 \nFiori, 1 Cuori, 1 Picche, 
Dialogue: 0,0:0:50.92,0:0:53.67,Default,,0000,0000,0000,,se dici 2 Quadri, quello \ne' il Terzo colore, 
Dialogue: 0,0:0:53.67,0:0:56.54,Default,,0000,0000,0000,,perche' avresti potuto \nanche ripetere le Cuori 
Dialogue: 0,0:0:56.54,0:0:56.66,Default,,0000,0000,0000,,. 
Dialogue: 0,0:0:56.66,0:0:59.59,Default,,0000,0000,0000,,Il Terzo colore allunga \nil colore che hai detto 
Dialogue: 0,0:0:59.59,0:1:2.16,Default,,0000,0000,0000,,prima: stai dicendo che \nle tue Cuori sono 
Dialogue: 0,0:1:2.16,0:1:3.06,Default,,0000,0000,0000,,almeno quinte. 
Dialogue: 0,0:1:3.06,0:1:5.98,Default,,0000,0000,0000,,Il Quarto colore e' \nquando c' e' UN SOLO colore 
Dialogue: 0,0:1:5.98,0:1:7.00,Default,,0000,0000,0000,,rimasto da dire. 
Dialogue: 0,0:1:7.00,0:1:9.87,Default,,0000,0000,0000,,Per esempio: dopo 1 \nQuadri, 1 Picche, 2 Fiori, 
Dialogue: 0,0:1:9.87,0:1:12.74,Default,,0000,0000,0000,,l'unico colore non \nancora detto sono le Cuori. 
Dialogue: 0,0:1:12.74,0:1:15.43,Default,,0000,0000,0000,,Se dici 2 Cuori, quello \ne' il Quarto colore 
Dialogue: 0,0:1:15.43,0:1:15.97,Default,,0000,0000,0000,,forcing. 
Dialogue: 0,0:1:15.97,0:1:17.76,Default,,0000,0000,0000,,Non promette carte in \nCuori! 
Dialogue: 0,0:1:17.76,0:1:20.57,Default,,0000,0000,0000,,E' un messaggio \nconvenzionale che dice: `` Ho 
Dialogue: 0,0:1:20.57,0:1:23.38,Default,,0000,0000,0000,,abbastanza punti per la \nmanche ma non so dove 
Dialogue: 0,0:1:23.38,0:1:23.91,Default,,0000,0000,0000,,giocare. 
Dialogue: 0,0:1:23.91,0:1:25.71,Default,,0000,0000,0000,,Descrivi meglio la tua \nmano! 
Dialogue: 0,0:1:25.71,0:1:28.52,Default,,0000,0000,0000,,'' Il Quarto colore e' \nforcing manche, il che 
Dialogue: 0,0:1:28.52,0:1:31.39,Default,,0000,0000,0000,,significa che una volta \nche lo dici, la coppia 
Dialogue: 0,0:1:31.39,0:1:33.06,Default,,0000,0000,0000,,DEVE arrivare alla \nmanche. 
Dialogue: 0,0:1:33.06,0:1:34.91,Default,,0000,0000,0000,,Non ci si puo' fermare \nprima. 
Dialogue: 0,0:1:34.91,0:1:37.60,Default,,0000,0000,0000,,Per questo servono \nalmeno 12 o 13 punti per 
Dialogue: 0,0:1:37.60,0:1:38.08,Default,,0000,0000,0000,,usarlo. 
Dialogue: 0,0:1:38.08,0:1:40.77,Default,,0000,0000,0000,,Non puoi dire il Quarto \ncolore con una mano 
Dialogue: 0,0:1:40.77,0:1:41.25,Default,,0000,0000,0000,,debole! 
Dialogue: 0,0:1:41.25,0:1:44.12,Default,,0000,0000,0000,,C' e' un'eccezione: se \nil Quarto colore capita 
Dialogue: 0,0:1:44.12,0:1:46.98,Default,,0000,0000,0000,,a livello 1, cioe' la \nsequenza e' tipo 1 Fiori 
Dialogue: 0,0:1:46.98,0:1:49.91,Default,,0000,0000,0000,,1 Quadri, 1 Cuori, 1 \nPicche, allora e' forzante 
Dialogue: 0,0:1:49.91,0:1:52.01,Default,,0000,0000,0000,,solo per un giro, non \nper manche. 
Dialogue: 0,0:1:52.01,0:1:51.29,Default,,0000,0000,0000,,Ma questa e' l'unica \neccezione. 
Dialogue: 0,0:1:51.29,0:1:53.82,Default,,0000,0000,0000,,Ora vediamo cosa fa \nl'Apertore quando il 
Dialogue: 0,0:1:53.82,0:1:55.76,Default,,0000,0000,0000,,compagno usa il Quarto \ncolore. 
Dialogue: 0,0:1:55.76,0:1:58.71,Default,,0000,0000,0000,,Ha una lista di priorita \nda seguire nell'ordine 
Dialogue: 0,0:1:58.71,0:1:58.83,Default,,0000,0000,0000,,. 
Dialogue: 0,0:1:58.83,0:2:1.37,Default,,0000,0000,0000,,E' come una scala: si \nscende gradino per 
Dialogue: 0,0:2:1.37,0:2:1.91,Default,,0000,0000,0000,,gradino. 
Dialogue: 0,0:2:1.91,0:2:4.51,Default,,0000,0000,0000,,Priorita' numero uno: \nappoggiare il primo 
Dialogue: 0,0:2:4.51,0:2:6.86,Default,,0000,0000,0000,,colore del rispondente \ncon fit terzo! 
Dialogue: 0,0:2:6.86,0:2:9.76,Default,,0000,0000,0000,,Se il rispondente ha \ndetto Picche e l'apertore 
Dialogue: 0,0:2:9.76,0:2:11.81,Default,,0000,0000,0000,,ha tre Picche, deve \nappoggiarle. 
Dialogue: 0,0:2:11.81,0:2:14.59,Default,,0000,0000,0000,,Questo e' \nimportantissimo specialmente con i 
Dialogue: 0,0:2:14.59,0:2:17.18,Default,,0000,0000,0000,,nobili: un nobile chiede \nsempre di essere 
Dialogue: 0,0:2:17.18,0:2:17.91,Default,,0000,0000,0000,,appoggiato. 
Dialogue: 0,0:2:17.91,0:2:20.86,Default,,0000,0000,0000,,Priorita' numero due: \ndichiarare Senza Atout se 
Dialogue: 0,0:2:20.86,0:2:22.79,Default,,0000,0000,0000,,ha il fermo nel Quarto \ncolore. 
Dialogue: 0,0:2:22.79,0:2:25.51,Default,,0000,0000,0000,,Per esempio, se il \nQuarto colore e' Cuori e 
Dialogue: 0,0:2:25.51,0:2:28.35,Default,,0000,0000,0000,,l'apertore ha il Re o la \nDonna di Cuori, dice 
Dialogue: 0,0:2:28.35,0:2:29.13,Default,,0000,0000,0000,,Senza Atout. 
Dialogue: 0,0:2:29.13,0:2:31.91,Default,,0000,0000,0000,,Priorita' numero tre: \nripetere un suo colore 
Dialogue: 0,0:2:31.91,0:2:33.72,Default,,0000,0000,0000,,per mostrare piu' \nlunghezza. 
Dialogue: 0,0:2:33.72,0:2:35.83,Default,,0000,0000,0000,,Se ha un colore sesto, \nlo ripete. 
Dialogue: 0,0:2:35.83,0:2:38.61,Default,,0000,0000,0000,,Priorita' numero quattro \nrialzare nel Quarto 
Dialogue: 0,0:2:38.61,0:2:40.78,Default,,0000,0000,0000,,colore con 4 carte in \nquel colore. 
Dialogue: 0,0:2:40.78,0:2:41.99,Default,,0000,0000,0000,,Raro, ma possibile. 
Dialogue: 0,0:2:41.99,0:2:44.64,Default,,0000,0000,0000,,Priorita' numero cinque \nfare un `` allungo 
Dialogue: 0,0:2:44.64,0:2:45.43,Default,,0000,0000,0000,,impossibile. 
Dialogue: 0,0:2:45.43,0:2:48.14,Default,,0000,0000,0000,,'' Cioe' dichiarare \nqualcosa che sembra non 
Dialogue: 0,0:2:48.14,0:2:50.98,Default,,0000,0000,0000,,avere senso, ma che \nserve solo a negare tutte 
Dialogue: 0,0:2:50.98,0:2:52.37,Default,,0000,0000,0000,,le opzioni precedenti. 
Dialogue: 0,0:2:52.37,0:2:53.70,Default,,0000,0000,0000,,E' l'ultima spiaggia. 
Dialogue: 0,0:2:53.70,0:2:56.23,Default,,0000,0000,0000,,La regola d'oro e': se \npiu' opzioni sono 
Dialogue: 0,0:2:56.23,0:2:59.07,Default,,0000,0000,0000,,disponibili, la priorita \ne' sempre fit nobile 
Dialogue: 0,0:2:59.07,0:3:1.90,Default,,0000,0000,0000,,prima di tutto, poi \nSenza Atout, poi mostrare 
Dialogue: 0,0:3:1.90,0:3:2.75,Default,,0000,0000,0000,,le lunghezze. 
Dialogue: 0,0:3:2.75,0:3:5.52,Default,,0000,0000,0000,,Adesso parliamo di \nquando il fit maggiore e' 
Dialogue: 0,0:3:5.52,0:3:6.73,Default,,0000,0000,0000,,gia' stato trovato. 
Dialogue: 0,0:3:6.73,0:3:9.57,Default,,0000,0000,0000,,Per esempio, hai aperto \n1 Cuori e il compagno 
Dialogue: 0,0:3:9.57,0:3:11.14,Default,,0000,0000,0000,,ha appoggiato a 2 Cuori . 
Dialogue: 0,0:3:11.14,0:3:11.98,Default,,0000,0000,0000,,Il fit c' e'! 
Dialogue: 0,0:3:11.98,0:3:13.55,Default,,0000,0000,0000,,Ma la manche si fa o no ? 
Dialogue: 0,0:3:13.55,0:3:16.33,Default,,0000,0000,0000,,Lo spazio tra 2 Cuori e \n3 Cuori e' riservato 
Dialogue: 0,0:3:16.33,0:3:18.14,Default,,0000,0000,0000,,alle indagini per la \nmanche. 
Dialogue: 0,0:3:18.14,0:3:20.91,Default,,0000,0000,0000,,Se il compagno, dopo \nl'appoggio a 2, dice un 
Dialogue: 0,0:3:20.91,0:3:23.51,Default,,0000,0000,0000,,colore nuovo, sta \nfacendo un tentativo di 
Dialogue: 0,0:3:23.51,0:3:23.99,Default,,0000,0000,0000,,manche. 
Dialogue: 0,0:3:23.99,0:3:26.89,Default,,0000,0000,0000,,Sta chiedendo: `` Hai \nvalori in questo colore? 
Dialogue: 0,0:3:26.89,0:3:29.85,Default,,0000,0000,0000,,'' Se l'apertore ha \nl'Asso, il Re o la Donna in 
Dialogue: 0,0:3:29.85,0:3:32.38,Default,,0000,0000,0000,,quel colore, rialza a \nmanche, a 4 Cuori. 
Dialogue: 0,0:3:32.38,0:3:35.22,Default,,0000,0000,0000,,Se ha solo cartine, \nriporta a 3 Cuori dicendo 
Dialogue: 0,0:3:35.22,0:3:37.27,Default,,0000,0000,0000,,`` mi spiace, non ho \nniente li'. 
Dialogue: 0,0:3:37.27,0:3:39.87,Default,,0000,0000,0000,,'' Se ha cartine nel \ncolore chiesto ma un 
Dialogue: 0,0:3:39.87,0:3:42.52,Default,,0000,0000,0000,,valore importante in un \nALTRO colore, puo' 
Dialogue: 0,0:3:42.52,0:3:45.30,Default,,0000,0000,0000,,mostrare quell'altro \ncolore, purche' rimanga 
Dialogue: 0,0:3:45.30,0:3:46.50,Default,,0000,0000,0000,,sotto 3 nell'atout. 
Dialogue: 0,0:3:46.50,0:3:49.04,Default,,0000,0000,0000,,E poi c' e' il 2 Senza \nAtout come invito 
Dialogue: 0,0:3:49.04,0:3:49.64,Default,,0000,0000,0000,,generico. 
Dialogue: 0,0:3:49.64,0:3:52.54,Default,,0000,0000,0000,,Dopo l'appoggio a 2 nel \nnobile, l'apertore puo 
Dialogue: 0,0:3:52.54,0:3:55.38,Default,,0000,0000,0000,,dire 2 Senza Atout per \nchiedere genericamente 
Dialogue: 0,0:3:55.38,0:3:57.61,Default,,0000,0000,0000,,se il compagno e' \nmassimo o minimo. 
Dialogue: 0,0:3:57.61,0:4:0.51,Default,,0000,0000,0000,,Non e' un cambio di \nrotta verso il Senza Atout 
Dialogue: 0,0:4:0.51,0:4:0.63,Default,,0000,0000,0000,,! 
Dialogue: 0,0:4:0.63,0:4:3.58,Default,,0000,0000,0000,,Il contratto finira' \ncomunque nel nobile, a 3 o 
Dialogue: 0,0:4:3.58,0:4:5.52,Default,,0000,0000,0000,,a 4, a seconda della \nrisposta. 
Dialogue: 0,0:4:5.52,0:4:7.63,Default,,0000,0000,0000,,Ci vediamo alla prossima \nlezione! 
